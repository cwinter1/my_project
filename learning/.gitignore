# ── Generated output artifacts from running lesson notebooks ──────────────────
# These files are created BY the exercises, not needed TO run them.
# Every student generates their own version locally.

# Databases created by SQL/ETL exercises
*.db
*.sqlite
*.sqlite3

# CSVs generated by exercises (datasets/ folder is explicitly kept below)
Curriculum/Week_*/*.csv

# Log files
*.log
Curriculum/Week_*/logs/

# Other generated output files from exercises
Curriculum/Week_*/*.txt
Curriculum/Week_*/*.json

# ── Keep these (source files, not generated) ──────────────────────────────────
!Curriculum/datasets/**
!CLAUDE.md
!README.md
!**/*.ipynb
!**/*.py
!**/*.xlsx

# ── Python / OS noise ─────────────────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
Thumbs.db
